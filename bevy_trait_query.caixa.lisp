   :body "[package]\ncategories  = { workspace = true }\ndescription = \"Implementation of trait queries for the bevy game engine\"\nedition     = { workspace = true }\nkeywords    = { workspace = true }\nlicense     = { workspace = true }\nname        = \"bevy-trait-query\"\nrepository  = { workspace = true }\nversion     = \"0.18.0\"\n\n[features]\ndefault = [\"bevy_app\"]\ntrace = [\"dep:tracing\"]\n\n[dependencies]\nbevy-trait-query-impl = { workspace = true }\nbevy_app              = { default-features = false, optional = true, workspace = true }\nbevy_ecs              = { default-features = false, workspace = true }\ntracing               = { default-features = false, optional = true, workspace = true }\n\n[dev-dependencies]\nbevy      = { default-features = false, workspace = true }\ncriterion = { workspace = true }\n\n[[bench]]\nharness = false\nname    = \"concrete\"\npath    = \"../benches/concrete.rs\"\n\n[[bench]]\nharness = false\nname    = \"all\"\npath    = \"../benches/all.rs\"\n\n[[bench]]\nharness = false\nname    = \"one\"\npath    = \"../benches/one.rs\"\n\n[[bench]]\nharness = false\nname    = \"fragmented\"\npath    = \"../benches/fragmented.rs\"\n"} {:path "bevy-trait-query/src/lib.rs"
   :sha256 "9aab2e07a6c195ba04b0657357251c64629e3b7e7e6221d12a3984bac148b7f7"
